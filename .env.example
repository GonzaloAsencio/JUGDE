# === Database ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === LLM Provider ===
# Options: "gemini" (default) | "openai_compat"
LLM_PROVIDER=gemini

# --- Gemini (default, production) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- Groq (deploy alternativo — 14,400 req/día gratis) ---
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# --- LM Studio (desarrollo local — sin rate limits) ---
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=nombre-del-modelo-cargado

# === Embedder ===
MODEL_NAME=BAAI/bge-m3

# === Cache (Upstash Redis — opcional) ===
# UPSTASH_REDIS_URL=https://...
# UPSTASH_REDIS_TOKEN=...

# === Observability (opcional) ===
# LANGFUSE_SECRET_KEY=...
# LANGFUSE_PUBLIC_KEY=...
# SENTRY_DSN=...
