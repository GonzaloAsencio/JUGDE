# === LLM (generation) ===
# LLM_PROVIDER: "gemini" (default) | "openai_compat" (Groq, LM Studio, Ollama, etc.)
GEMINI_API_KEY=
LLM_PROVIDER=openai_compat
# openai_compat requires all 3 together: BASE_URL, API_KEY, and MODEL — missing
# one and the backend refuses to start (Settings validates this at startup).
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile

# === Judge (Cerebras — separate judge so it doesn't share quota with generation) ===
# Optional: if unset, the judge falls back to LLM_* (shares quota with the
# pipeline), and if that's also unset, falls back to GEMINI_API_KEY.
JUDGE_BASE_URL=https://api.cerebras.ai/v1
JUDGE_API_KEY=
JUDGE_MODEL=gpt-oss-120b

# === Database ===
# Postgres with pgvector enabled (hosted on Supabase, but connected to directly
# via psycopg2 — the Supabase SDK/client is not used, only the connection string).
DATABASE_URL=

# === Proxy auth ===
# Required in production — the backend refuses to start if app_env=production
# and this is unset (fail-closed). Empty/unset = auth disabled (local dev).
PROXY_SHARED_SECRET=

# === Cache (Upstash Redis — optional, cache disabled without it) ===
# Use the READ-WRITE token from the Upstash dashboard, not the read-only one.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# === Observability (optional) ===
# SENTRY_SAMPLE_RATE defaults to 0.1 (only 10% of errors reported) if unset.
SENTRY_SAMPLE_RATE=1.0
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# === Frontend ===
# FRONTEND variable (frontend/.env.local), not read by the backend. Local: http://localhost:8000
FASTAPI_URL=

# === App ===
APP_VERSION=1.0.0
CORPUS_VERSION=v2.1.0
TOP_K=10
TOP_K_FETCH=10