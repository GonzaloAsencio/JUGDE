# === Required ===
DATABASE_URL=postgresql://user:password@host:5432/dbname
GEMINI_API_KEY=your-gemini-api-key

# === Runtime environment (development | staging | production) ===
APP_ENV=development

# === Upstash Redis - response cache (leave blank to disable cache) ===
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-token

# === Langfuse - LLM observability (leave blank to disable tracing) ===
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === Sentry - error reporting (leave blank to disable) ===
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz

# === Rate limiting ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=10
RATE_LIMIT_PER_DAY=100
