# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Env
.env
.env.local
.env.*.local

# Data - raw files never go to git (keep dirs via .gitkeep)
backend/data/raw/*
!backend/data/raw/.gitkeep
backend/data/processed/*
!backend/data/processed/.gitkeep
# rulebook.md and cards.md stopped being intermediate build artifacts when
# hard-query routing (4.2+4.3) started reading them at RUNTIME: the stuffed
# context is built from these files, so they must ship with the git checkout
# (the Dockerfile COPYs the checkout — ignored files never reach prod or CI).
!backend/data/processed/rulebook.md
!backend/data/processed/cards.md
backend/data/cards/cards.json
backend/data/cards/keywords_dictionary.json
backend/data/eval_runs/*
!backend/data/eval_runs/.gitkeep
backend/data/eval_results_*.json

# Keep eval_set.json and eval_set_metadata.json in git (curated, versioned)
!backend/data/eval_set.json
!backend/data/eval_set_metadata.json

# Corpus backups (CSV dumps de corpus_chunks, local only)
backend/backups/

# Node
node_modules/
.next/
out/
*.tsbuildinfo
frontend/.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# AI tooling (local only)
.claude/
.atl/
.agents/
skills-lock.json

# Scratch / dry-run output (local only)
backend/dry.txt

# Dev server logs (local only)
*.dev.log
*.dev.err.log
backend/*.log
